# =============================
# SmartShop AI - Environment Config
# KHÔNG commit file này lên Git!
# =============================

# --- LLM Provider ---
# Chọn một trong hai: "openai" hoặc "gemini"
LLM_PROVIDER=openai

# --- OpenAI (mặc định) ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # Để trống = dùng OpenAI chính thức

# ==========================================
# --- Groq (OpenAI-compatible, MIỄN PHÍ) ---
# Lấy API key tại: https://console.groq.com/keys
# ==========================================
# OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# Model Groq khác: llama-3.1-8b-instant | gemma2-9b-it | mixtral-8x7b-32768

# --- Google Gemini ---
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash


# --- CORS ---
# Frontend URL (Next.js dev server)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- App Config ---
APP_ENV=development
LOG_LEVEL=INFO

# ==========================================
# --- LangSmith Tracing (AI Observability) ---
# Giám sát toàn bộ luồng Agent, RAG, chi phí token
# Đăng ký miễn phí tại: https://smith.langchain.com/
# ==========================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_your-langsmith-key-here
LANGCHAIN_PROJECT=SmartShop-AI
